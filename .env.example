# ==========================================
# LG전자 산학협력 프로젝트 환경 변수
# 🚨 경고: 실제 키가 들어간 .env 파일은 절대 Git에 커밋하지 마세요!
# ==========================================

# 1. OpenAI API 키 (GPT-4o 등 멀티모달, 텍스트 정제용)
# 발급처: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-여기에_실제_오픈에이아이_키를_붙여넣으세요"

# 2. Anthropic API 키 (Claude 3.5 Sonnet 등 텍스트/표 변환용)
# 발급처: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-여기에_실제_클로드_키를_붙여넣으세요"

# 3. (선택) Hugging Face 토큰 
# Marker나 LayoutLM 같은 오픈소스 Vision 모델 중 권한이 필요한 모델을 다운로드할 때 쓰일 수 있음
# 발급처: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN="hf_여기에_허깅페이스_토큰을_붙여넣으세요"

# 4. (선택) 시스템 및 디버그 설정
# 앱 개발 중 오류 메시지를 더 자세히 보고 싶을 때 사용
DEBUG_MODE="True"
